@model ErrorViewModel

@{
    ViewData["Title"] = "Error";
}

<div class="row justify-content-center mt-4">
    <div class="col-lg-7 col-md-9">

        <div class="text-center mb-5">
            <div style="font-size:5rem; line-height:1; margin-bottom:.75rem;">
                <i class="bi bi-exclamation-octagon-fill text-danger"></i>
            </div>
            <h1 class="fw-bold text-danger section-title">Something went wrong</h1>
            <p class="text-muted">An error occurred while processing your request.</p>
        </div>

        @if (Model.ShowRequestId)
        {
            <div class="alert alert-secondary d-flex align-items-center gap-2" role="alert">
                <i class="bi bi-info-circle-fill flex-shrink-0"></i>
                <div><strong>Request ID:</strong> <code>@Model.RequestId</code></div>
            </div>
        }

        <div class="card shadow border-0">
            <div class="card-header py-3" style="background:linear-gradient(to right,#fefce8,#fef9c3);">
                <h5 class="mb-0 fw-bold">
                    <i class="bi bi-wrench me-2 text-warning"></i>Development Mode
                </h5>
            </div>
            <div class="card-body p-4 text-muted">
                <p>
                    Switching to <strong>Development</strong> environment will display more detailed information
                    about the error that occurred.
                </p>
                <p class="mb-0">
                    <strong>The Development environment should not be enabled for deployed applications</strong>
                    as it may expose sensitive exception details to end users.
                    For local debugging, set the <strong>ASPNETCORE_ENVIRONMENT</strong> variable to
                    <code>Development</code> and restart the app.
                </p>
            </div>
        </div>

        <div class="mt-4 text-center">
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary px-5">
                <i class="bi bi-house-door me-1"></i>Return Home
            </a>
        </div>

    </div>
</div>
