@*
 * ============================================================================
 * DotNet Bookstore — In-Class ASP.NET Core MVC Project
 * Course: COMP2084 | Georgian College | Summer 2026
 * Instructor: Dario Hesami
 * ============================================================================
 *
 * FILE:    Views/Home/Privacy.cshtml
 * PURPOSE: A static informational page describing the application's privacy
 *          policy. It contains no database queries or form logic — it is a
 *          pure read-only content page served by HomeController.Privacy().
 *
 * KEY CONCEPTS FOR STUDENTS:
 *  1. Static content views — not every view needs a model or database access.
 *                            Simple informational pages like Privacy, About,
 *                            or Help are just Razor files with static HTML.
 *  2. Bootstrap card layout — .card, .card-body, .card-header provide a clean
 *                             framed container for the page content.
 *  3. asp-controller/asp-action — the "Back to Home" button uses Tag Helpers
 *                             to generate the correct URL, staying in sync with
 *                             routing even if URLs change.
 * ============================================================================
 *@

@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="row justify-content-center">
    @* col-lg-8: limits the content width on large screens for readability *@
    <div class="col-lg-8">

        @* ── Page header with back button ─────────────────────────────────── *@
        <div class="d-flex align-items-center mb-4">
            @* Back button: asp-* Tag Helpers generate href="/Home/Index" *@
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-sm me-3" title="Back to Home">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h2 class="mb-0 fw-bold section-title">
                <i class="bi bi-shield-lock me-2 text-primary"></i>Privacy Policy
            </h2>
        </div>

        @* ── Privacy content card ─────────────────────────────────────────── *@
        <div class="card shadow border-0">
            @* p-md-5 applies extra padding on medium+ screens for a comfortable reading margin *@
            <div class="card-body p-4 p-md-5">

                @* Decorative icon and heading *@
                <div class="text-center mb-4">
                    <div class="stat-icon bg-primary bg-opacity-10 text-primary mx-auto mb-3">
                        <i class="bi bi-shield-check"></i>
                    </div>
                    <h4 class="fw-bold">Your Privacy Matters</h4>
                </div>

                @* Privacy policy placeholder text — replace with real legal content *@
                <p class="text-muted">
                    Use this page to detail your site's privacy policy.
                    DotNet Bookstore is committed to protecting your personal information and
                    being transparent about how it is used.
                </p>

                @* Decorative gradient divider defined in site.css *@
                <hr class="divider-gradient my-4" />

                <p class="text-muted mb-0">
                    For questions about this privacy policy, please contact the site administrator.
                </p>
            </div>
        </div>

    </div>
</div>
