@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="row justify-content-center">
    <div class="col-lg-8">

        <div class="d-flex align-items-center mb-4">
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-sm me-3" title="Back to Home">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h2 class="mb-0 fw-bold section-title">
                <i class="bi bi-shield-lock me-2 text-primary"></i>Privacy Policy
            </h2>
        </div>

        <div class="card shadow border-0">
            <div class="card-body p-4 p-md-5">
                <div class="text-center mb-4">
                    <div class="stat-icon bg-primary bg-opacity-10 text-primary mx-auto mb-3">
                        <i class="bi bi-shield-check"></i>
                    </div>
                    <h4 class="fw-bold">Your Privacy Matters</h4>
                </div>
                <p class="text-muted">
                    Use this page to detail your site's privacy policy.
                    DotNet Bookstore is committed to protecting your personal information and
                    being transparent about how it is used.
                </p>
                <hr class="divider-gradient my-4" />
                <p class="text-muted mb-0">
                    For questions about this privacy policy, please contact the site administrator.
                </p>
            </div>
        </div>

    </div>
</div>
