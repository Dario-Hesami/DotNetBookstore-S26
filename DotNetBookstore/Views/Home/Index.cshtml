@* This is the view for the home page. *@

@{
    @* ViewData["Title"] is used to set the title of the page. *@
    ViewData["Title"] = "Home Page";
}

@* Hero section *@
<div class="p-5 mb-4 bg-dark text-white rounded-3 shadow">
    <div class="container-fluid py-3 text-center">
        <i class="bi bi-book-half display-1 mb-3 d-block text-warning"></i>
        <h1 class="display-5 fw-bold">Welcome to DotNet Bookstore</h1>
        <p class="col-md-8 fs-5 mx-auto text-white-50">
            Your one-stop destination for discovering and managing books. Browse our catalogue, explore categories, and find your next great read.
        </p>
        <div class="mt-4 d-flex gap-3 justify-content-center flex-wrap">
            <a asp-controller="Books" asp-action="Index" class="btn btn-warning btn-lg px-4 fw-semibold">
                <i class="bi bi-journal-bookmark me-2"></i>Browse Books
            </a>
            <a asp-controller="Categories" asp-action="Index" class="btn btn-outline-light btn-lg px-4">
                <i class="bi bi-tags me-2"></i>View Categories
            </a>
        </div>
    </div>
</div>

@* Feature cards *@
<div class="row row-cols-1 row-cols-md-3 g-4 mb-4">
    <div class="col">
        <div class="card h-100 border-0 shadow-sm text-center">
            <div class="card-body p-4">
                <i class="bi bi-search display-5 text-primary mb-3 d-block"></i>
                <h5 class="card-title fw-semibold">Discover Books</h5>
                <p class="card-text text-muted">Browse our full catalogue of books across a wide range of categories and genres.</p>
            </div>
            <div class="card-footer bg-transparent border-0 pb-4">
                <a asp-controller="Books" asp-action="Index" class="btn btn-primary btn-sm px-3">
                    <i class="bi bi-arrow-right me-1"></i>Go to Books
                </a>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100 border-0 shadow-sm text-center">
            <div class="card-body p-4">
                <i class="bi bi-tags display-5 text-success mb-3 d-block"></i>
                <h5 class="card-title fw-semibold">Browse Categories</h5>
                <p class="card-text text-muted">Explore books by category to quickly find titles that match your interests.</p>
            </div>
            <div class="card-footer bg-transparent border-0 pb-4">
                <a asp-controller="Categories" asp-action="Index" class="btn btn-success btn-sm px-3">
                    <i class="bi bi-arrow-right me-1"></i>Go to Categories
                </a>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100 border-0 shadow-sm text-center">
            <div class="card-body p-4">
                <i class="bi bi-person-circle display-5 text-warning mb-3 d-block"></i>
                <h5 class="card-title fw-semibold">Manage Your Account</h5>
                <p class="card-text text-muted">Register or log in to manage books and categories within the bookstore system.</p>
            </div>
            <div class="card-footer bg-transparent border-0 pb-4">
                <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-warning btn-sm px-3">
                    <i class="bi bi-arrow-right me-1"></i>Get Started
                </a>
            </div>
        </div>
    </div>
</div>

