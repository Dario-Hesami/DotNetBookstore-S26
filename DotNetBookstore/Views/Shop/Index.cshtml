@model IEnumerable<DotNetBookstore.Models.Category>
@{
    ViewData["Title"] = "Shop";
}

<div class="container py-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb bg-transparent p-0 mb-2">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">Shop</li>
        </ol>
    </nav>
    <div class="text-center">
        <h1 class="display-5 fw-bold mb-1">Shop</h1>
        <p class="lead text-muted mb-0">Browse categories to start discovering great books.</p>
    </div>
</div>

@if (!Model?.Any() ?? true)
{
    <div class="container">
        <div class="alert alert-info">No categories are available at the moment. Please check back later or <a asp-controller="Home" asp-action="Index">return home</a>.</div>
    </div>
}
else
{
    <div class="container">
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-4">
            @foreach (var cat in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-body d-flex flex-column">
                            <div class="d-flex align-items-center mb-3">
                                <div class="me-3">
                                    <div class="bg-warning text-white rounded-circle d-flex align-items-center justify-content-center" style="width:56px;height:56px;">
                                        <i class="bi bi-tags fs-4"></i>
                                    </div>
                                </div>
                                <div>
                                    <h5 class="card-title mb-1">@cat.Name</h5>
                                    <small class="text-muted">@((cat.Books?.Count() ?? 0)) books</small>
                                </div>
                            </div>

                            <p class="card-text text-muted flex-grow-1">Discover hand-picked titles from the @cat.Name category.</p>

                            <div class="mt-3">
                                <a asp-controller="Shop" asp-action="ShopByCategory" asp-route-categoryId="@cat.CategoryId" class="btn btn-outline-primary w-100" aria-label="Browse @cat.Name books">
                                    <i class="bi bi-box-seam me-2"></i>Browse books
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}