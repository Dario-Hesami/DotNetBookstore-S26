@model DotNetBookstore.Models.Book

@{
    ViewData["Title"] = "Add New Book";
}

<div class="row justify-content-center">
    <div class="col-lg-6 col-md-8">

        <div class="d-flex align-items-center mb-4">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm me-3">
                <i class="bi bi-arrow-left"></i>
            </a>
            <div>
                <h2 class="mb-0 fw-bold"><i class="bi bi-plus-circle me-2 text-primary"></i>Add New Book</h2>
                <p class="text-muted mb-0 mt-1 small">Fill in the details below to add a new book.</p>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Author" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-person"></i></span>
                            <input asp-for="Author" class="form-control" placeholder="Author name" />
                        </div>
                        <span asp-validation-for="Author" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-book"></i></span>
                            <input asp-for="Title" class="form-control" placeholder="Book title" />
                        </div>
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Image" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-image"></i></span>
                            <input asp-for="Image" class="form-control" placeholder="https://..." />
                        </div>
                        <span asp-validation-for="Image" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Price" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-currency-dollar"></i></span>
                            <input asp-for="Price" class="form-control" placeholder="0.00" />
                        </div>
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input asp-for="MatureContent" class="form-check-input" role="switch" id="matureSwitch" />
                            <label asp-for="MatureContent" class="form-check-label fw-semibold" for="matureSwitch">
                                <i class="bi bi-exclamation-triangle me-1 text-warning"></i>Mature Content
                            </label>
                        </div>
                        <span asp-validation-for="MatureContent" class="text-danger small"></span>
                    </div>

                    @*
                        FIX AFTER SCAFFOLDING (Step 3): The scaffolder generated a plain <input> textbox
                        for CategoryId because it only knows it is a required integer field. A user cannot
                        be expected to type a raw database ID. We replace it with a <select> dropdown fed
                        by ViewBag.CategoryId (a SelectList built in the Create GET action in the controller).
                        asp-for="CategoryId" binds the selected value back to Book.CategoryId on POST.
                        asp-items="ViewBag.CategoryId" populates the <option> list from the SelectList.
                        The placeholder option ("-- Select a Category --") forces the user to make a choice.
                        The Category, CartItems, and OrderDetails <input> groups are removed entirely —
                        those are navigation/collection properties managed by EF, never entered by the user.
                    *@
                    <div class="mb-4">
                        <label asp-for="CategoryId" class="form-label fw-semibold"><i class="bi bi-tag me-1"></i>Category</label>
                        <select asp-for="CategoryId" asp-items="ViewBag.CategoryId" class="form-select">
                            <option value="">-- Select a Category --</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-check-circle me-1"></i>Create Book
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">
                            <i class="bi bi-x-circle me-1"></i>Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}