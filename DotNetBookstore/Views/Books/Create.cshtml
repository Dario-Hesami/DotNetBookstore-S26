@*
 * ============================================================================
 * DotNet Bookstore — In-Class ASP.NET Core MVC Project
 * Course: COMP2084 | Georgian College | Summer 2026
 * Instructor: Dario Hesami
 * ============================================================================
 *
 * FILE:    Views/Books/Create.cshtml
 * PURPOSE: The "Add New Book" form. Collects Author, Title, a cover image file,
 *          Price, Mature Content flag, and Category, then posts them to
 *          BooksController.Create (POST) for validation, image upload, and
 *          database insertion.
 *
 * KEY CONCEPTS FOR STUDENTS:
 *  1. @model Book               — strongly typed to the Book entity. Tag Helpers
 *                                 (asp-for) use this type to find property names,
 *                                 validation rules, and display names automatically.
 *  2. enctype="multipart/form-data" — REQUIRED for file uploads. Tells the
 *                                 browser to encode the form in multiple parts so
 *                                 that binary file content can be transmitted
 *                                 alongside the text fields. Without this attribute
 *                                 the file bytes are never sent to the server.
 *  3. type="file" accept="..."  — renders the native OS file-picker dialog.
 *                                 The accept attribute restricts the picker to
 *                                 PNG and JPEG files (client-side hint only —
 *                                 server-side validation also applies in the controller).
 *  4. name="Image"              — the form field name must match the IFormFile
 *                                 parameter name declared in the controller action
 *                                 so ASP.NET Core can bind the uploaded stream.
 *  5. asp-action="Create"       — Tag Helper on the <form> tag. Generates:
 *                                 action="/Books/Create" method="post" and adds the
 *                                 hidden __RequestVerificationToken for CSRF protection.
 *  6. asp-for="Author"          — on a <label>: renders the [Display] name.
 *                                 On an <input>: sets name, id, and value from the model.
 *  7. asp-validation-for        — renders a <span> that shows the server-side error
 *                                 message for that field and is also used by jQuery
 *                                 Validation for inline client-side error messages.
 *  8. asp-validation-summary="ModelOnly" — shows model-level errors (not
 *                                 field-level) at the top of the form in a red alert.
 *  9. asp-items="ViewBag.CategoryId" — populates the <select> options from the
 *                                 SelectList that the controller put in ViewBag.
 * 10. FileReader API (JS)       — reads the selected file directly in the browser
 *                                 as a base-64 Data URL for the live preview, WITHOUT
 *                                 uploading it to the server. The actual upload only
 *                                 happens when the form is submitted.
 * 11. @section Scripts          — injects view-specific JavaScript into the "Scripts"
 *                                 section of _Layout.cshtml (after jQuery is loaded).
 * ============================================================================
 *@

@* Strongly-typed model: the form posts data that populates a Book object *@
@model DotNetBookstore.Models.Book

@{
    ViewData["Title"] = "Add New Book";
}

@* justify-content-center: centers the narrow form column horizontally *@
<div class="row justify-content-center">
    @* col-xl-5 col-lg-6 col-md-8: responsive width — narrower on large screens,
       wider on small ones — ensures a readable form layout at all sizes *@
    <div class="col-xl-5 col-lg-6 col-md-8">

        @* ── Back button + page title ─────────────────────────────────────── *@
        <div class="d-flex align-items-center mb-4">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm me-3" title="Back to list">
                <i class="bi bi-arrow-left"></i>
            </a>
            <div>
                <h2 class="mb-0 fw-bold section-title">
                    <i class="bi bi-plus-circle me-2 text-primary"></i>Add New Book
                </h2>
                <p class="text-muted mb-0 mt-1 small">Fill in the details below to add a new book.</p>
            </div>
        </div>

        <div class="card shadow border-0">
            <div class="card-body p-4">

                @*
                   enctype="multipart/form-data" — CRITICAL for file uploads.
                   Without it the browser only sends the filename as text, never
                   the file bytes. The controller's IFormFile Image parameter
                   will always be null if this attribute is missing.
                   asp-action="Create" also injects a hidden CSRF token field.
                *@
                <form asp-action="Create" enctype="multipart/form-data">

                    @* Shows model-level validation errors (not individual field errors) *@
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" role="alert"></div>

                    @* ── Author field ──────────────────────────────────────── *@
                    <div class="mb-3">
                        @* asp-for="Author" on label renders the [Display] name + links label to input *@
                        <label asp-for="Author" class="form-label fw-semibold small text-uppercase text-muted"></label>
                        @* input-group: icon prefix + text input grouped visually *@
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-person"></i></span>
                            @* asp-for="Author" on input: sets name="Author", id="Author",
                               and wires up data-val-* attributes for client-side validation *@
                            <input asp-for="Author" class="form-control" placeholder="Author name" />
                        </div>
                        @* Shows the validation error for Author if the field fails (e.g., empty or too long) *@
                        <span asp-validation-for="Author" class="text-danger small"></span>
                    </div>

                    @* ── Title field ───────────────────────────────────────── *@
                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-semibold small text-uppercase text-muted"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-book"></i></span>
                            <input asp-for="Title" class="form-control" placeholder="Book title" />
                        </div>
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    @* ── Cover Image file upload with live preview ─────────── *@
                    <div class="mb-3">
                        @* Custom label text: "Cover Image" is clearer than the raw property name *@
                        <label class="form-label fw-semibold small text-uppercase text-muted">
                            <i class="bi bi-image me-1"></i>Cover Image
                        </label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-upload"></i></span>
                            @*
                               type="file"   — opens the OS file picker dialog
                               name="Image"  — must match the IFormFile parameter name in Create POST
                               id="imageInput" — referenced by the JS preview script below
                               accept="image/png, image/jpeg" — hints to the OS file picker
                                              to filter to PNG and JPEG files (client-side only;
                                              the server does not currently enforce a type check,
                                              so in production you would validate ContentType too)
                            *@
                            <input type="file" name="Image" id="imageInput"
                                   class="form-control" accept="image/png, image/jpeg" />
                        </div>
                        <div class="form-text text-muted small">
                            Accepted formats: PNG, JPEG. Leave empty to save the book without a cover image.
                        </div>

                        @* Live preview container — hidden by default (d-none), revealed by JS *@
                        <div id="imagePreviewWrapper" class="mt-3 text-center d-none">
                            <div class="d-inline-block rounded-2 overflow-hidden shadow-sm"
                                 style="width:110px;height:160px;background:var(--brand-gradient-light)">
                                <img id="imagePreview" src="" alt="Cover preview"
                                     style="width:100%;height:100%;object-fit:cover;" />
                            </div>
                            <div class="text-muted small mt-1">Cover Preview</div>
                        </div>
                    </div>

                    @* ── Price field ───────────────────────────────────────── *@
                    <div class="mb-3">
                        <label asp-for="Price" class="form-label fw-semibold small text-uppercase text-muted"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-currency-dollar"></i></span>
                            <input asp-for="Price" class="form-control" placeholder="0.00" />
                        </div>
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>

                    @* ── Mature Content toggle switch ──────────────────────── *@
                    <div class="mb-3">
                        @* form-switch renders the checkbox as a Bootstrap toggle slider *@
                        <div class="form-check form-switch p-3 rounded-2 bg-indigo-subtle">
                            <input asp-for="MatureContent" class="form-check-input" role="switch" id="matureSwitch" />
                            <label asp-for="MatureContent" class="form-check-label fw-semibold" for="matureSwitch">
                                <i class="bi bi-exclamation-triangle me-1 text-warning"></i>Mature Content
                            </label>
                            <div class="text-muted small mt-1">
                                Enable for books with adult themes, violence, or explicit content.
                            </div>
                        </div>
                        <span asp-validation-for="MatureContent" class="text-danger small"></span>
                    </div>

                    @* ── Category dropdown ─────────────────────────────────── *@
                    <div class="mb-4">
                        <label asp-for="CategoryId" class="form-label fw-semibold small text-uppercase text-muted">
                            <i class="bi bi-tag me-1"></i>Category
                        </label>
                        @* asp-for="CategoryId" binds the selected value to Book.CategoryId.
                           asp-items="ViewBag.CategoryId" uses the SelectList from the controller
                           to populate the <option> elements. *@
                        <select asp-for="CategoryId" asp-items="ViewBag.CategoryId" class="form-select">
                            @* Default empty option prompts user to make a selection *@
                            <option value="">— Select a Category —</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger small"></span>
                    </div>

                    @* Decorative gradient <hr> defined in site.css *@
                    <hr class="divider-gradient" />

                    @* ── Action buttons ────────────────────────────────────── *@
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-check-circle me-1"></i>Create Book
                        </button>
                        @* Cancel returns to the book list without saving *@
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">
                            <i class="bi bi-x-circle me-1"></i>Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

@* ── View-specific JavaScript (injected into _Layout's Scripts section) ───── *@
@section Scripts {
    @* Load the jQuery Validation libraries needed for client-side validation *@
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }

    <script>
        /*
         * LIVE COVER IMAGE PREVIEW (FileReader API)
         * ──────────────────────────────────────────
         * When the user selects a file with the file picker, this code reads it
         * in the browser using the FileReader API and displays it as a preview
         * BEFORE the form is submitted.
         *
         * WHY FileReader instead of a URL string?
         *   In the old URL-based approach the Image field was a text input and the
         *   browser could load the image by pointing src at the typed URL.
         *   Now Image is an <input type="file"> — no URL exists yet. FileReader
         *   reads the file bytes directly from disk and converts them to a base-64
         *   Data URL (data:image/jpeg;base64,...) that the browser can show inline.
         *   The file is NOT uploaded to the server at this point; that only happens
         *   on form submit.
         *
         * FileReader.readAsDataURL(file)
         *   Reads the file asynchronously. When done it fires the onload event
         *   with event.target.result set to the base-64 Data URL.
         *
         * The IIFE (Immediately Invoked Function Expression) — (function(){ ... })()
         * — creates a private scope so variables (input, wrapper, preview)
         * don't pollute the global window object.
         */
        (function () {
            var input   = document.getElementById('imageInput');       // the file input element
            var wrapper = document.getElementById('imagePreviewWrapper'); // the preview container
            var preview = document.getElementById('imagePreview');     // the <img> element

            if (!input) return; // safety guard: exit if element is missing

            input.addEventListener('change', function () {
                var file = input.files && input.files[0]; // grab the first selected file

                if (!file) {
                    // User cleared the selection — hide the preview
                    wrapper.classList.add('d-none');
                    return;
                }

                // Use FileReader to read the file as a base-64 Data URL
                var reader = new FileReader();
                reader.onload = function (e) {
                    // e.target.result is the data:image/...;base64,... string
                    preview.src = e.target.result;
                    wrapper.classList.remove('d-none'); // reveal the preview box
                };
                reader.readAsDataURL(file); // triggers the async read
            });
        })();
    </script>
}
