@model DotNetBookstore.Models.Book

@{
    ViewData["Title"] = "Book Details";
}

<div class="row justify-content-center">
    <div class="col-xl-8 col-lg-10">

        <div class="d-flex align-items-center mb-4">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm me-3" title="Back to list">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h2 class="mb-0 fw-bold section-title">
                <i class="bi bi-eye me-2 text-info"></i>Book Details
            </h2>
        </div>

        <div class="card shadow border-0">
            <div class="card-body p-0">
                <div class="row g-0">

                    @* ── Cover column ──────────────────────────────────────── *@
                    <div class="col-md-3">
                        <div class="book-cover-wrapper h-100"
                             style="min-height:280px; border-radius:var(--radius-card) 0 0 var(--radius-card);">
                            <i class="bi bi-book-half book-cover-placeholder" aria-hidden="true"></i>
                            @if (!string.IsNullOrWhiteSpace(Model?.Image))
                            {
                                <img src="@Model.Image" alt="@Model.Title cover"
                                     class="cover-img"
                                     onerror="this.style.display='none'" />
                            }
                        </div>
                    </div>

                    @* ── Info column ───────────────────────────────────────── *@
                    <div class="col-md-9">
                        <div class="p-4 h-100 d-flex flex-column">

                            @* Badges *@
                            <div class="mb-3 d-flex flex-wrap gap-2">
                                @if (!string.IsNullOrWhiteSpace(Model?.Category?.Name))
                                {
                                    <span class="badge bg-secondary rounded-pill px-3 py-2">
                                        <i class="bi bi-tag me-1"></i>@Model.Category.Name
                                    </span>
                                }
                                @if (Model?.MatureContent == true)
                                {
                                    <span class="badge bg-danger rounded-pill px-3 py-2">
                                        <i class="bi bi-18-up me-1"></i>Mature Content
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-success rounded-pill px-3 py-2">
                                        <i class="bi bi-check-circle me-1"></i>All Ages
                                    </span>
                                }
                            </div>

                            <h3 class="fw-bold mb-1 section-title">@Model?.Title</h3>
                            <p class="text-muted mb-3 fs-6">
                                <i class="bi bi-person me-1"></i>by <strong>@Model?.Author</strong>
                            </p>

                            <hr class="divider-gradient" />

                            <dl class="row mb-0 flex-grow-1">
                                <dt class="col-sm-4 text-muted small fw-semibold text-uppercase py-1">Price</dt>
                                <dd class="col-sm-8 fw-bold fs-4 text-success py-1 mb-0">
                                    $@Model?.Price.ToString("0.00")
                                </dd>

                                <dt class="col-sm-4 text-muted small fw-semibold text-uppercase py-1">Author</dt>
                                <dd class="col-sm-8 py-1 mb-0">@Model?.Author</dd>

                                <dt class="col-sm-4 text-muted small fw-semibold text-uppercase py-1">Category</dt>
                                <dd class="col-sm-8 py-1 mb-0">
                                    <span class="badge bg-secondary">@Html.DisplayFor(m => m.Category.Name)</span>
                                </dd>

                                <dt class="col-sm-4 text-muted small fw-semibold text-uppercase py-1">Rating</dt>
                                <dd class="col-sm-8 py-1 mb-0">
                                    @if (Model?.MatureContent == true)
                                    {
                                        <span class="badge bg-danger"><i class="bi bi-18-up me-1"></i>Mature</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>All Ages</span>
                                    }
                                </dd>
                            </dl>

                        </div>
                    </div>

                </div>
            </div>

            <div class="card-footer bg-transparent d-flex flex-wrap gap-2 px-4 pb-4 pt-3">
                <a asp-action="Edit" asp-route-id="@Model?.BookId" class="btn btn-primary">
                    <i class="bi bi-pencil me-1"></i>Edit Book
                </a>
                <a asp-action="Delete" asp-route-id="@Model?.BookId" class="btn btn-outline-danger">
                    <i class="bi bi-trash me-1"></i>Delete
                </a>
                <a asp-action="Index" class="btn btn-outline-secondary ms-auto">
                    <i class="bi bi-arrow-left me-1"></i>Back to List
                </a>
            </div>
        </div>

    </div>
</div>
