@model IEnumerable<DotNetBookstore.Models.Book>

@{
    ViewData["Title"] = "Books";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-0 fw-bold"><i class="bi bi-journal-bookmark me-2 text-primary"></i>Books</h2>
        <p class="text-muted mb-0 mt-1">Manage the bookstore catalogue</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>Add New Book
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th><i class="bi bi-person me-1"></i>@Html.DisplayNameFor(model => model.Author)</th>
                        <th><i class="bi bi-book me-1"></i>@Html.DisplayNameFor(model => model.Title)</th>
                        <th><i class="bi bi-image me-1"></i>Cover</th>
                        <th><i class="bi bi-currency-dollar me-1"></i>@Html.DisplayNameFor(model => model.Price)</th>
                        <th><i class="bi bi-exclamation-triangle me-1"></i>@Html.DisplayNameFor(model => model.MatureContent)</th>
                        @*
                            FIX AFTER SCAFFOLDING (Step 3): Replace the raw CategoryId column (a meaningless
                            integer FK number) and the Category navigation-property column with a single
                            "Category Name" column that shows the human-readable category name.
                            CartItems and OrderDetails are reverse navigation collections — they represent
                            other tables' rows that reference this book and have no meaning as list columns.
                            All four scaffolded columns are removed and replaced by this one.
                        *@
                        <th><i class="bi bi-tag me-1"></i>Category</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@Html.DisplayFor(model => item.Author)</td>
                            <td>@Html.DisplayFor(model => item.Title)</td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(item.Image))
                                {
                                    <img src="@item.Image" alt="@item.Title cover" class="rounded"
                                         style="width:48px;height:60px;object-fit:cover;"
                                         onerror="this.style.display='none'" />
                                }
                                else
                                {
                                    <span class="text-muted fst-italic">No image</span>
                                }
                            </td>
                            <td class="fw-semibold text-success">$@item.Price.ToString("0.00")</td>
                            <td>
                                @if (item.MatureContent)
                                {
                                    <span class="badge bg-danger"><i class="bi bi-18-up me-1"></i>Mature</span>
                                }
                                else
                                {
                                    <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>All Ages</span>
                                }
                            </td>
                            @*
                            FIX AFTER SCAFFOLDING (Step 3): Display the category name via the Category navigation
                            property (item.Category.Name) instead of the raw FK integer (item.CategoryId).
                            This works because the controller's Index action now uses .Include(b => b.Category)
                            to eagerly load the related Category row for every Book in the query.
                            The CartItems and OrderDetails cells are removed entirely — they are reverse
                            navigation collections that belong to other tables and are meaningless here.
                            *@
                            <td><span class="badge bg-secondary">@Html.DisplayFor(model => item.Category.Name)</span></td>
                            <td class="text-center text-nowrap">
                                <a asp-action="Edit" asp-route-id="@item.BookId" class="btn btn-outline-primary btn-sm me-1" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Details" asp-route-id="@item.BookId" class="btn btn-outline-info btn-sm me-1" title="Details">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.BookId" class="btn btn-outline-danger btn-sm" title="Delete">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    @if (!Model.Any())
    {
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-journal-x display-4 d-block mb-2"></i>
            <p class="mb-0">No books found. <a asp-action="Create">Add the first book</a>.</p>
        </div>
    }
</div>