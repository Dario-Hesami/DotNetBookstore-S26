@model DotNetBookstore.Models.Book

@{
    ViewData["Title"] = "Delete Book";
}

<div class="row justify-content-center">
    <div class="col-lg-6 col-md-8">

        <div class="d-flex align-items-center mb-4">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm me-3" title="Back to list">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h2 class="mb-0 fw-bold text-danger">
                <i class="bi bi-trash me-2"></i>Delete Book
            </h2>
        </div>

        @* Warning banner *@
        <div class="alert alert-danger d-flex align-items-start gap-3 mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill fs-4 flex-shrink-0 mt-1"></i>
            <div>
                <div class="fw-semibold">This action is permanent and cannot be undone.</div>
                <div class="small mt-1 opacity-75">
                    The book and all associated data will be permanently removed from the catalogue.
                </div>
            </div>
        </div>

        @* Book preview card *@
        <div class="card shadow border-danger" style="border-width:2px !important;">
            <div class="card-body p-0">
                <div class="row g-0">

                    @* Cover thumbnail *@
                    <div class="col-3">
                        <div class="book-cover-wrapper h-100"
                             style="min-height:200px; border-radius:var(--radius-card) 0 0 0;">
                            <i class="bi bi-book-half book-cover-placeholder" aria-hidden="true"></i>
                            @if (!string.IsNullOrWhiteSpace(Model?.Image))
                            {
                                <img src="@Model.Image" alt="@Model.Title cover"
                                     class="cover-img"
                                     onerror="this.style.display='none'" />
                            }
                        </div>
                    </div>

                    @* Details *@
                    <div class="col-9 p-4">
                        <h5 class="fw-bold mb-1">@Model?.Title</h5>
                        <p class="text-muted small mb-3"><i class="bi bi-person me-1"></i>@Model?.Author</p>
                        <dl class="row mb-0 small">
                            <dt class="col-5 text-muted">Price</dt>
                            <dd class="col-7 fw-semibold text-success mb-1">$@Model?.Price.ToString("0.00")</dd>

                            <dt class="col-5 text-muted">Category</dt>
                            <dd class="col-7 mb-1">
                                <span class="badge bg-secondary">@Html.DisplayFor(m => m.Category.Name)</span>
                            </dd>

                            <dt class="col-5 text-muted">Rating</dt>
                            <dd class="col-7 mb-0">
                                @if (Model?.MatureContent == true)
                                {
                                    <span class="badge bg-danger"><i class="bi bi-18-up me-1"></i>Mature</span>
                                }
                                else
                                {
                                    <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>All Ages</span>
                                }
                            </dd>
                        </dl>
                    </div>

                </div>
            </div>

            <div class="card-footer bg-transparent d-flex gap-2 px-4 pb-4 pt-3">
                <form asp-action="Delete">
                    <input type="hidden" asp-for="BookId" />
                    <button type="submit" class="btn btn-danger px-4">
                        <i class="bi bi-trash me-1"></i>Yes, Delete Permanently
                    </button>
                </form>
                <a asp-action="Index" class="btn btn-outline-secondary px-4">
                    <i class="bi bi-x-circle me-1"></i>Cancel
                </a>
            </div>
        </div>

    </div>
</div>
