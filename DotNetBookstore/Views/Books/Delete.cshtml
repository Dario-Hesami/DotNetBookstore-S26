@*
 * ============================================================================
 * DotNet Bookstore — In-Class ASP.NET Core MVC Project
 * Course: COMP2084 | Georgian College | Summer 2026
 * Instructor: Dario Hesami
 * ============================================================================
 *
 * FILE:    Views/Books/Delete.cshtml
 * PURPOSE: Confirmation page shown before permanently deleting a book.
 *          The user sees the book's details and must explicitly click
 *          "Yes, Delete Permanently" to proceed.
 *
 * KEY CONCEPTS FOR STUDENTS:
 *  1. Two-step delete (GET → POST)
 *         GET  /Books/Delete/5  → this view (show confirmation)
 *         POST /Books/Delete/5  → BooksController.DeleteConfirmed (do the delete)
 *     This pattern prevents accidental or malicious deletions triggered by a
 *     simple link click (since GET requests should never modify data).
 *  2. Delete form with hidden BookId — the confirmation form posts only the BookId
 *                              (via a hidden field) to identify which record to remove.
 *                              No user-editable fields are needed.
 *  3. [ValidateAntiForgeryToken] — the form's asp-action Tag Helper adds the CSRF
 *                              token; the controller's [ValidateAntiForgeryToken]
 *                              attribute verifies it. This prevents another site from
 *                              tricking a logged-in user into deleting data.
 *  4. Danger styling          — the red border, red header, and warning alert
 *                              use Bootstrap's danger colour scheme to visually
 *                              communicate that this is a destructive, irreversible action.
 *  5. Cancel button           — always provide a safe escape route. The Cancel
 *                              button is a plain link (not a form submit) that
 *                              returns to the Index without any database change.
 * ============================================================================
 *@

@model DotNetBookstore.Models.Book

@{
    ViewData["Title"] = "Delete Book";
}

<div class="row justify-content-center">
    <div class="col-lg-6 col-md-8">

        @* ── Page title + back button ─────────────────────────────────────── *@
        <div class="d-flex align-items-center mb-4">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm me-3" title="Back to list">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h2 class="mb-0 fw-bold text-danger">
                <i class="bi bi-trash me-2"></i>Delete Book
            </h2>
        </div>

        @* ── Warning alert ────────────────────────────────────────────────── *@
        @* This prominent warning tells the user the deletion is permanent.
           d-flex + align-items-start keeps the icon aligned with the top of the text. *@
        <div class="alert alert-danger d-flex align-items-start gap-3 mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill fs-4 flex-shrink-0 mt-1"></i>
            <div>
                <div class="fw-semibold">This action is permanent and cannot be undone.</div>
                <div class="small mt-1 opacity-75">
                    The book and all associated data will be permanently removed from the catalogue.
                </div>
            </div>
        </div>

        @* ── Book preview card (bordered in red to signal danger) ─────────── *@
        <div class="card shadow border-danger" style="border-width:2px !important;">
            <div class="card-body p-0">
                <div class="row g-0">

                    @* Small cover thumbnail *@
                    <div class="col-3">
                        <div class="book-cover-wrapper h-100"
                             style="min-height:200px; border-radius:var(--radius-card) 0 0 0;">
                            <i class="bi bi-book-half book-cover-placeholder" aria-hidden="true"></i>
                            @if (!string.IsNullOrWhiteSpace(Model?.Image))
                            {
                                <img src="@Model.Image" alt="@Model.Title cover"
                                     class="cover-img"
                                     onerror="this.style.display='none'" />
                            }
                        </div>
                    </div>

                    @* Book summary: title, author, price, category, rating *@
                    <div class="col-9 p-4">
                        <h5 class="fw-bold mb-1">@Model?.Title</h5>
                        <p class="text-muted small mb-3"><i class="bi bi-person me-1"></i>@Model?.Author</p>

                        @* dl = definition list for compact key/value display *@
                        <dl class="row mb-0 small">
                            <dt class="col-5 text-muted">Price</dt>
                            <dd class="col-7 fw-semibold text-success mb-1">$@Model?.Price.ToString("0.00")</dd>

                            <dt class="col-5 text-muted">Category</dt>
                            <dd class="col-7 mb-1">
                                <span class="badge bg-secondary">@Html.DisplayFor(m => m.Category.Name)</span>
                            </dd>

                            <dt class="col-5 text-muted">Rating</dt>
                            <dd class="col-7 mb-0">
                                @if (Model?.MatureContent == true)
                                {
                                    <span class="badge bg-danger"><i class="bi bi-18-up me-1"></i>Mature</span>
                                }
                                else
                                {
                                    <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>All Ages</span>
                                }
                            </dd>
                        </dl>
                    </div>

                </div>
            </div>

            @* ── Confirm deletion form ─────────────────────────────────────── *@
            <div class="card-footer bg-transparent d-flex gap-2 px-4 pb-4 pt-3">
                @* The form only contains a hidden BookId field — no user input.
                   Submitting it triggers the POST Delete action in the controller. *@
                <form asp-action="Delete">
                    @* Hidden field carries the BookId to the server so the controller
                       knows which book to delete. asp-for generates: name="BookId" value="5" *@
                    <input type="hidden" asp-for="BookId" />
                    <button type="submit" class="btn btn-danger px-4">
                        <i class="bi bi-trash me-1"></i>Yes, Delete Permanently
                    </button>
                </form>
                @* Cancel is a plain link — clicking it simply navigates away
                   without POSTing anything to the server *@
                <a asp-action="Index" class="btn btn-outline-secondary px-4">
                    <i class="bi bi-x-circle me-1"></i>Cancel
                </a>
            </div>
        </div>

    </div>
</div>
