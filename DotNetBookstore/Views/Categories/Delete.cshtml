@model DotNetBookstore.Models.Category

@{
    ViewData["Title"] = "Delete Category";
}

<div class="row justify-content-center">
    <div class="col-lg-5 col-md-7">

        <div class="d-flex align-items-center mb-4">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm me-3">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h2 class="mb-0 fw-bold text-danger"><i class="bi bi-trash me-2"></i>Delete Category</h2>
        </div>

        <div class="alert alert-danger d-flex align-items-center" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
            <div>Are you sure you want to permanently delete this category? This action cannot be undone.</div>
        </div>

        <div class="card shadow-sm border-danger border-2">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0"><i class="bi bi-tag me-2"></i>@Model?.Name</h5>
            </div>
            <div class="card-body p-4">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted"><i class="bi bi-tag me-1"></i>@Html.DisplayNameFor(model => model.Name)</dt>
                    <dd class="col-sm-8 fw-semibold">@Html.DisplayFor(model => model.Name)</dd>
                </dl>
            </div>
            <div class="card-footer bg-transparent d-flex gap-2 pb-4 px-4">
                <form asp-action="Delete">
                    <input type="hidden" asp-for="CategoryId" />
                    <button type="submit" class="btn btn-danger px-4">
                        <i class="bi bi-trash me-1"></i>Yes, Delete
                    </button>
                </form>
                <a asp-action="Index" class="btn btn-outline-secondary px-4">
                    <i class="bi bi-x-circle me-1"></i>Cancel
                </a>
            </div>
        </div>

    </div>
</div>
