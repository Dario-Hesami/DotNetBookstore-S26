@model DotNetBookstore.Models.Category

@{
    ViewData["Title"] = "Delete Category";
}

<div class="row justify-content-center">
    <div class="col-lg-5 col-md-7">

        <div class="d-flex align-items-center mb-4">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm me-3" title="Back to list">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h2 class="mb-0 fw-bold text-danger">
                <i class="bi bi-trash me-2"></i>Delete Category
            </h2>
        </div>

        @* Warning banner *@
        <div class="alert alert-danger d-flex align-items-start gap-3 mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill fs-4 flex-shrink-0 mt-1"></i>
            <div>
                <div class="fw-semibold">This action is permanent and cannot be undone.</div>
                <div class="small mt-1 opacity-75">
                    Deleting this category may affect books that are currently assigned to it.
                </div>
            </div>
        </div>

        <div class="card shadow border-danger" style="border-width:2px !important;">
            <div class="card-header bg-danger text-white py-3"
                 style="border-radius:var(--radius-card) var(--radius-card) 0 0 !important;">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-tag fs-5"></i>
                    <h5 class="mb-0 fw-bold">@Model?.Name</h5>
                </div>
            </div>

            <div class="card-body p-4">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted small fw-semibold text-uppercase">Category Name</dt>
                    <dd class="col-sm-8 fw-semibold">@Html.DisplayFor(m => m.Name)</dd>
                </dl>
            </div>

            <div class="card-footer bg-transparent d-flex gap-2 px-4 pb-4 pt-3">
                <form asp-action="Delete">
                    <input type="hidden" asp-for="CategoryId" />
                    <button type="submit" class="btn btn-danger px-4">
                        <i class="bi bi-trash me-1"></i>Yes, Delete Permanently
                    </button>
                </form>
                <a asp-action="Index" class="btn btn-outline-secondary px-4">
                    <i class="bi bi-x-circle me-1"></i>Cancel
                </a>
            </div>
        </div>

    </div>
</div>
