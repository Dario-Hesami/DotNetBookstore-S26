@model DotNetBookstore.Models.Category

@{
    ViewData["Title"] = "Category Details";
}

<div class="row justify-content-center">
    <div class="col-lg-5 col-md-7">

        <div class="d-flex align-items-center mb-4">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm me-3">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h2 class="mb-0 fw-bold"><i class="bi bi-eye me-2 text-info"></i>Category Details</h2>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0"><i class="bi bi-tag me-2"></i>@Model?.Name</h5>
            </div>
            <div class="card-body p-4">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted"><i class="bi bi-tag me-1"></i>@Html.DisplayNameFor(model => model.Name)</dt>
                    <dd class="col-sm-8 fw-semibold">@Html.DisplayFor(model => model.Name)</dd>
                </dl>
            </div>
            <div class="card-footer bg-transparent d-flex gap-2 pb-4 px-4">
                <a asp-action="Edit" asp-route-id="@Model?.CategoryId" class="btn btn-primary btn-sm">
                    <i class="bi bi-pencil me-1"></i>Edit
                </a>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-list me-1"></i>Back to List
                </a>
            </div>
        </div>

    </div>
</div>
