@*
 * ============================================================================
 * DotNet Bookstore — In-Class ASP.NET Core MVC Project
 * Course: COMP2084 | Georgian College | Summer 2026
 * Instructor: Dario Hesami
 * ============================================================================
 *
 * FILE:    Views/Categories/Index.cshtml
 * PURPOSE: Lists all book categories as a responsive card grid.
 *          Each card shows the category name and action buttons (View, Edit, Delete).
 *          If no categories exist, an "empty state" encourages the user to create one.
 *
 * KEY CONCEPTS FOR STUDENTS:
 *  1. @model IEnumerable<Category> — the controller passes all categories
 *                                    retrieved from the database as the model.
 *  2. Model.ToList()               — called once at the top to prevent double-
 *                                    enumeration (for .Count + foreach loop).
 *  3. Conditional plural           — @(catList.Count == 1 ? "y" : "ies") renders
 *                                    "1 category" or "3 categories" correctly.
 *  4. Responsive grid              — row-cols-lg-4 gives 4 columns on large screens,
 *                                    row-cols-md-3 on medium, row-cols-sm-2 on small,
 *                                    row-cols-1 on mobile.
 *  5. Empty state pattern          — same pattern as Books/Index.cshtml. Never show
 *                                    a blank page — always guide the user to take action.
 * ============================================================================
 *@

@model IEnumerable<DotNetBookstore.Models.Category>

@{
    ViewData["Title"] = "Categories";
    var catList = Model.ToList(); // materialise once to avoid double-enumeration
}

@* ── Page header: title + count + "Add Category" button ──────────────────── *@
<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2 class="mb-0 fw-bold section-title">
            <i class="bi bi-tags me-2 text-success"></i>Categories
        </h2>
        @* Pluralisation: "1 category" vs "3 categories" *@
        <p class="text-muted mb-0 mt-1 small">
            @catList.Count categor@(catList.Count == 1 ? "y" : "ies") defined
        </p>
    </div>
    @* asp-action="Create" generates href="/Categories/Create" *@
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-circle me-1"></i>Add Category
    </a>
</div>

@* ── Category card grid ───────────────────────────────────────────────────── *@
@if (catList.Any())
{
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
        @foreach (var item in catList)
        {
            <div class="col">
                @* card-hover: lift animation on hover (defined in site.css) *@
                <div class="card card-hover h-100 border-0 shadow-sm text-center">
                    <div class="card-body p-4">
                        @* stat-icon: rounded icon badge (defined in site.css) *@
                        <div class="stat-icon bg-success bg-opacity-10 text-success mx-auto">
                            <i class="bi bi-tag"></i>
                        </div>
                        <h5 class="card-title fw-bold mb-0">@item.Name</h5>
                    </div>
                    @* Action buttons: View / Edit / Delete — each includes the category ID in the URL *@
                    <div class="card-footer bg-transparent border-0 d-flex gap-1 justify-content-center pb-3">
                        <a asp-action="Details" asp-route-id="@item.CategoryId"
                           class="btn btn-outline-info btn-sm" title="View details">
                            <i class="bi bi-eye me-1"></i>View
                        </a>
                        <a asp-action="Edit" asp-route-id="@item.CategoryId"
                           class="btn btn-outline-primary btn-sm" title="Edit">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.CategoryId"
                           class="btn btn-outline-danger btn-sm" title="Delete">
                            <i class="bi bi-trash"></i>
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    @* ── Empty state: shown when no categories have been created yet ──────── *@
    <div class="empty-state">
        <span class="empty-icon"><i class="bi bi-tags"></i></span>
        <h5 class="text-muted fw-semibold">No categories yet</h5>
        <p class="text-muted small mb-3">Create your first category to start organising books.</p>
        <a asp-action="Create" class="btn btn-success px-4">
            <i class="bi bi-plus-circle me-1"></i>Add First Category
        </a>
    </div>
}
