@model IEnumerable<DotNetBookstore.Models.Category>

@{
    ViewData["Title"] = "Categories";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-0 fw-bold"><i class="bi bi-tags me-2 text-success"></i>Categories</h2>
        <p class="text-muted mb-0 mt-1">Manage book categories</p>
    </div>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-circle me-1"></i>Add Category
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th><i class="bi bi-tag me-1"></i>@Html.DisplayNameFor(model => model.Name)</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@Html.DisplayFor(model => item.Name)</td>
                            <td class="text-center text-nowrap">
                                <a asp-action="Edit" asp-route-id="@item.CategoryId" class="btn btn-outline-primary btn-sm me-1" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Details" asp-route-id="@item.CategoryId" class="btn btn-outline-info btn-sm me-1" title="Details">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.CategoryId" class="btn btn-outline-danger btn-sm" title="Delete">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    @if (!Model.Any())
    {
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-tags display-4 d-block mb-2"></i>
            <p class="mb-0">No categories found. <a asp-action="Create">Add the first category</a>.</p>
        </div>
    }
</div>
